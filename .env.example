# Copia este archivo a .env y añade tus claves API
OPENAI_API_KEY=tu-api-key-de-openai

# Langfuse - Observabilidad y tracking de LLM (opcional)
# Obtén tus credenciales en https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=tu-public-key
LANGFUSE_SECRET_KEY=tu-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com
